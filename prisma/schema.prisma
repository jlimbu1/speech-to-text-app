generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transcript {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  text         String   @default("")
  duration     Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
